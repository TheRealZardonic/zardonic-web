# ============================================================================
# ZARDONIC INDUSTRIAL — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# All variables marked [REQUIRED] must be set for production deployment.
# Variables marked [OPTIONAL] have sensible defaults.
# ============================================================================

# --- Upstash Redis (KV Store) ---
# [REQUIRED] Used for: rate limiting, sessions, caching, admin data, analytics
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Security ---
# [REQUIRED for production] Random salt for GDPR-compliant IP hashing in rate limiter
# Generate with: openssl rand -hex 32
RATE_LIMIT_SALT=

# [OPTIONAL] One-time token required during initial admin password setup
# If set, the setup form will require this token. Recommended for production.
ADMIN_SETUP_TOKEN=

# [AUTO] Set automatically by Vercel for cron job authentication.
# Required if using Vercel Cron Jobs. Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Spotify API ---
# [REQUIRED for Spotify features] Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Bandsintown API ---
# [REQUIRED for tour dates] Get your key at https://www.bandsintown.com/for-artists
BANDSINTOWN_API_KEY=

# --- Resend (Email) ---
# [OPTIONAL] Required only if contact form or newsletter features are used
RESEND_API_KEY=

# --- CORS ---
# [OPTIONAL] Restrict image proxy and API CORS origin. Defaults to '*'.
# Set to your production domain for security (e.g., https://zardonic.com)
ALLOWED_ORIGIN=

# --- Admin Password Reset ---
# [OPTIONAL] Admin email address for password reset feature.
# If not set, password reset endpoint returns 503.
ADMIN_RESET_EMAIL=

# --- Google Drive ---
# [OPTIONAL] API key for Google Drive folder integration (public media hosting).
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_API_KEY=

# --- Sanity CMS ---
# [REQUIRED for Sanity CMS] Project ID and dataset (Public - embedded in frontend bundle)
# Project: https://www.sanity.io/manage/project/unz85dqo
VITE_SANITY_PROJECT_ID=unz85dqo
VITE_SANITY_DATASET=production

# [REQUIRED for server-side writes] Sanity API token with Editor permissions (Server-Side - NEVER expose to client)
# Create at: https://www.sanity.io/manage/project/unz85dqo/api#tokens
SANITY_API_TOKEN=

# [OPTIONAL] Webhook secret for Sanity → Vercel cache revalidation
# Set when configuring a webhook in Sanity Dashboard → API → Webhooks
SANITY_WEBHOOK_SECRET=

# --- Vercel KV (Legacy) ---
# [AUTO] These are set automatically by Vercel when you link a KV store.
# Only needed if using @vercel/kv directly (image-proxy.ts uses this).
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
