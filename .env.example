# ============================================================================
# ZARDONIC INDUSTRIAL — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# All variables marked [REQUIRED] must be set for production deployment.
# Variables marked [OPTIONAL] have sensible defaults or enable optional features.
# ============================================================================

# --- Upstash Redis (KV Store) ---
# [REQUIRED] Used for: rate limiting, sessions, caching, admin data, analytics
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Security ---
# [REQUIRED] Random salt for GDPR-compliant IP hashing in rate limiter
# Generate with: openssl rand -hex 32
RATE_LIMIT_SALT=

# [OPTIONAL] One-time token required during initial admin password setup.
# If set, the setup form will require this token. Recommended for production.
ADMIN_SETUP_TOKEN=

# [OPTIONAL] Set automatically by Vercel for cron job authentication.
# Required if using Vercel Cron Jobs. Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Vercel Blob (Video / File Uploads) ---
# [REQUIRED for video uploads] Auto-provisioned in Vercel dashboard when Blob store is added.
# Used by the CMS video upload endpoint.
BLOB_READ_WRITE_TOKEN=

# --- Site Identity ---
# [OPTIONAL] Used in OG meta tags, security alert messages, TOTP issuer, email subjects, etc.
SITE_NAME=ZARDONIC
SITE_URL=https://your-domain.com
SITE_DESCRIPTION=Official website of ZARDONIC — drum & bass metal producer

# --- Spotify API ---
# [REQUIRED for Spotify features] Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Bandsintown API ---
# [REQUIRED for tour dates] Get your key at https://www.bandsintown.com/for-artists
BANDSINTOWN_API_KEY=

# --- Setlist.fm API ---
# [OPTIONAL] Required for setlist history features.
# Get your key at https://www.setlist.fm/settings/api
SETLISTFM_API_KEY=

# --- iTunes ---
# [OPTIONAL] Artist ID for iTunes release sync (e.g. 123456789).
# If not set, iTunes sync is skipped.
ITUNES_ARTIST_ID=

# --- Discogs API ---
# [OPTIONAL] Personal access token for Discogs release data.
# Discogs and iTunes are fetched in parallel; best-of-breed data is merged.
# Generate at: https://www.discogs.com/settings/developers → Generate new token
DISCOGS_TOKEN=

# --- Resend (Email) ---
# [OPTIONAL] Required for contact form and password reset emails.
RESEND_API_KEY=
# Sender address for outgoing emails (defaults to onboarding@resend.dev if unset)
RESEND_FROM_EMAIL=
# Fallback: from address used in security alert emails
EMAIL_FROM=

# --- Contact Form ---
# [OPTIONAL] Destination address for contact form submissions.
CONTACT_EMAIL=

# --- Newsletter ---
# [OPTIONAL] Mailchimp integration — both API key and list ID must be set.
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
# [OPTIONAL] Brevo (Sendinblue) integration — both API key and list ID must be set.
BREVO_API_KEY=
BREVO_LIST_ID=

# --- Admin ---
# [OPTIONAL] Admin email address for password reset. Returns 503 if not set.
ADMIN_RESET_EMAIL=

# --- Discord Security Alerts ---
# [OPTIONAL] Discord webhook URL for IDS/security alert notifications.
DISCORD_WEBHOOK_URL=

# --- CORS ---
# [OPTIONAL] Restrict image proxy and API CORS origin. Defaults to '*'.
# Set to your production domain for security (e.g., https://zardonic.com)
ALLOWED_ORIGIN=

# --- Google Drive ---
# [OPTIONAL] API key for Google Drive folder integration (public media hosting).
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_API_KEY=

# --- Google OAuth (Drive integration) ---
# [OPTIONAL] Required only if Google Drive OAuth flow is used.
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# App URL for OAuth redirect — defaults to SITE_URL
OAUTH_APP_URL=
# [REQUIRED if OAuth is enabled] 64-character hex key for encrypting OAuth tokens.
# Generate with: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=

# --- Activation (Multi-tenant / Licensing) ---
# [OPTIONAL] Activation key for this deployment instance.
VITE_ACTIVATION_KEY=
# [OPTIONAL] Override the activation API endpoint (e.g. for staging).
VITE_ACTIVATION_API_URL=
