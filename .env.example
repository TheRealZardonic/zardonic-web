# Upstash Redis (required for KV storage, sessions, rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Rate limiting (required in production — generate with: openssl rand -hex 32)
RATE_LIMIT_SALT=your-random-32-char-salt

# Admin setup token (optional — if set, initial password setup requires this token)
ADMIN_SETUP_TOKEN=your-optional-setup-token

# Discord webhook for security alerts (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Bandsintown API key (for gig listings)
BANDSINTOWN_API_KEY=your-bandsintown-api-key

# Resend API key (for contact form emails)
RESEND_API_KEY=re_your-resend-api-key

# Site URL (used in security alert messages)
SITE_URL=zardonic.com
